{
  "manifest_version": 3,
  "name": "Gemini Chat Navigator",
  "version": "1.0.0",
  "description": "Adds a minimal, right-side anchor navigation for your questions in Gemini chat.",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/app*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
